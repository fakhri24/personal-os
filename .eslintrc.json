{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": ["eslint:recommended", "prettier"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "script"
  },
  "rules": {
    "no-unused-vars": ["warn", {
      "argsIgnorePattern": "^_",
      "varsIgnorePattern": "^(navigateTo|toggleSidebar|openModal|closeModal|handleFormSubmit|editRow|deleteRow|markReviewed|loadTableData|loadDashboardStats|loadUpcomingReviews|testConnection|initRealtimeSubscription|escapeHtml|formatDate|formatDateTime|formatCurrency|isDateToday|isDateOverdue|showToast|withRetry|initErrorBoundary|sb|db|TABLES|currentTable|editingId|tableData|IdeasTable|ClothesTable|LearningTable|PackageTable|FilesTable|FinanceTable)$"
    }],
    "no-console": "off",
    "no-undef": "warn",
    "no-redeclare": "off",
    "no-case-declarations": "off"
  },
  "globals": {
    "sb": "writable",
    "db": "writable",
    "TABLES": "writable",
    "currentTable": "writable",
    "editingId": "writable",
    "tableData": "writable",
    "IdeasTable": "writable",
    "ClothesTable": "writable",
    "LearningTable": "writable",
    "PackageTable": "writable",
    "FilesTable": "writable",
    "FinanceTable": "writable",
    "escapeHtml": "readonly",
    "formatDate": "readonly",
    "formatDateTime": "readonly",
    "formatCurrency": "readonly",
    "isDateToday": "readonly",
    "isDateOverdue": "readonly",
    "showToast": "readonly",
    "withRetry": "readonly",
    "initErrorBoundary": "readonly",
    "navigateTo": "readonly",
    "toggleSidebar": "readonly",
    "openModal": "readonly",
    "closeModal": "readonly",
    "handleFormSubmit": "readonly",
    "editRow": "readonly",
    "deleteRow": "readonly",
    "markReviewed": "readonly",
    "loadTableData": "readonly",
    "loadDashboardStats": "readonly",
    "loadUpcomingReviews": "readonly",
    "testConnection": "readonly",
    "initRealtimeSubscription": "readonly",
    "supabase": "readonly"
  }
}
